__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Ambientes virtuais
.venv/
venv/
env/

# Saídas / artefactos
*.png
*.pth
*.pt

# IDE / SO
.vscode/
.idea/
.DS_Store
Thumbs.db
